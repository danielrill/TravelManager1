project_id = "your-gcp-project-id"

# Shared infra from terraform/ stack — change only if you renamed them there.
shared_region                            = "europe-west1"
existing_cloud_sql_instance_name         = "travelmanager-postgres"
existing_artifact_registry_repository_id = "travelmanager"

# VM placement.
region        = "europe-west3"
zone          = "europe-west3-a"
instance_name = "travelmanager-iaas"
machine_type  = "e2-standard-4"
disk_size_gb  = 30

# Image to deploy. Either set image_uri directly, or rely on image_name/image_tag.
image_name = "app"
image_tag  = "latest"
# image_uri = "europe-west1-docker.pkg.dev/your-gcp-project-id/travelmanager/app:latest"

# Database credentials — must match the values used by terraform/.
db_name     = "travelmanager"
db_user     = "travelmanager"
db_password = "REPLACE_ME"

# Domain pointing to the VM static IP. Set DNS A record AFTER first apply.
domain_name       = "iaas.example.com"
letsencrypt_email = "you@example.com"

# Firebase (mirror values from terraform/terraform.tfvars).
firebase_api_key        = ""
firebase_auth_domain    = ""
firebase_project_id     = ""
firebase_app_id         = ""
firebase_storage_bucket = ""
