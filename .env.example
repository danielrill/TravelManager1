# ── Firebase client (web app config) ──────────────────────────────────────────
NUXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NUXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

GOOGLE_CLOUD_PROJECT=

NODE_ENV=

# booking & flight API
RAPIDAPI_KEY=d38564ec22msh99886baf58b1a0bp11dfc9jsn197bad50284

# ── Google Maps ──────────────────────────────────────────────────────────────
# Browser key: loads the Maps JS + Places library in the SPA (map view,
# autocomplete). Restrict by HTTP referrer in the GCP console.
NUXT_PUBLIC_GOOGLE_MAPS_KEY=
# Server key: used by trip-service for geocoding destinations/locations.
# Restrict to the Geocoding API. Leave blank to fall back to keyless Open-Meteo.
GOOGLE_MAPS_SERVER_KEY=