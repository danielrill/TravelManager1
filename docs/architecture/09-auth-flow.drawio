<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-06-26" version="21.0.0">
  <diagram name="Auth-Flow" id="auth-flow">
    <mxGraphModel dx="1600" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Authentifizierung &amp; Autorisierung" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="900" height="40" as="geometry"/>
        </mxCell>

        <!-- ZONE 1: Client (Browser) -->
        <mxCell id="zone1" value="Client (Browser)" style="fillColor=#f5f5f5;strokeColor=#4a90d9;strokeWidth=2;verticalAlign=top;whiteSpace=wrap;html=1;rounded=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="350" height="720" as="geometry"/>
        </mxCell>

        <mxCell id="z1_sdk" value="Firebase SDK&#xa;initialisiert" style="fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="z1_login" value="Login/Register&#xa;(E-Mail oder Google OAuth)" style="fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="230" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="z1_create" value="createUserWithEmailPassword()&#xa;/ signInWith..." style="fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="z1_jwt" value="Firebase JWT (ID-Token)&#xa;(1h gültig, auto-refresh)" style="fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;whiteSpace=wrap;html=1;rounded=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="435" width="220" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="z1_bearer" value="Authorization: Bearer &lt;JWT&gt;&#xa;bei jeder API-Anfrage" style="fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="555" width="220" height="55" as="geometry"/>
        </mxCell>

        <!-- ZONE 2: API-Gateway -->
        <mxCell id="zone2" value="API-Gateway" style="fillColor=#f5f5f5;strokeColor=#4a90d9;strokeWidth=2;verticalAlign=top;whiteSpace=wrap;html=1;rounded=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="450" y="60" width="450" height="720" as="geometry"/>
        </mxCell>

        <mxCell id="z2_host" value="Host-Header Parsing&#xa;→ tenantId (z.B. &apos;tui&apos;)" style="fillColor=#fff2cc;strokeColor=#d6b656;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="130" width="300" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="z2_verify" value="firebase.auth().verifyIdToken(jwt)" style="fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;whiteSpace=wrap;html=1;rounded=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="230" width="300" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="z2_result" value="→ {uid, email, name, ...}" style="fillColor=#d5e8d4;strokeColor=#82b366;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="325" width="300" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="z2_cache" value="tenantId → Plan/Role lookup&#xa;(Redis-Cache)" style="fillColor=#d5e8d4;strokeColor=#82b366;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="415" width="300" height="55" as="geometry"/>
        </mxCell>

        <!-- Decision diamond -->
        <mxCell id="z2_decision" value="Plan check&#xa;Feature erlaubt?" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="510" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- 403 error box -->
        <mxCell id="z2_403" value="403 Forbidden" style="fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;whiteSpace=wrap;html=1;rounded=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="530" width="130" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="z2_inject" value="x-user-uid: abc123&#xa;x-user-email: user@...&#xa;x-tenant-id: tui&#xa;x-plan: standard&#xa;x-role: traveler" style="fillColor=#d5e8d4;strokeColor=#82b366;whiteSpace=wrap;html=1;rounded=1;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="640" width="300" height="90" as="geometry"/>
        </mxCell>

        <!-- ZONE 3: Microservices -->
        <mxCell id="zone3" value="Microservices (intern)" style="fillColor=#f5f5f5;strokeColor=#4a90d9;strokeWidth=2;verticalAlign=top;whiteSpace=wrap;html=1;rounded=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="980" y="60" width="450" height="720" as="geometry"/>
        </mxCell>

        <mxCell id="z3_mw" value="identity.js Middleware&#xa;→ req.user = {uid, tenantId, plan, role}" style="fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1020" y="130" width="300" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="z3_note" value="Kein zweites JWT-Verify&#xa;(Cluster-intern, NetworkPolicy)" style="fillColor=#f5f5f5;strokeColor=#666666;dashed=1;whiteSpace=wrap;html=1;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1020" y="245" width="300" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="z3_roles" value="Rollen-Check&#xa;(traveler / destinationMgr / operator)" style="fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1020" y="350" width="300" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="z3_db" value="tenantDb(tenantId)&#xa;→ DB-Routing" style="fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1020" y="455" width="300" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="z3_pool" value="Shared Pool (Free)&#xa;oder Dedicated Pool (Standard/Enterprise)" style="fillColor=#ffe6cc;strokeColor=#d6b656;whiteSpace=wrap;html=1;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1020" y="560" width="300" height="65" as="geometry"/>
        </mxCell>

        <!-- Firebase Auth external -->
        <mxCell id="firebase_ext" value="Firebase Auth&#xa;(Google Cloud)" style="fillColor=#ffecb3;strokeColor=#f9a825;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="60" width="300" height="55" as="geometry"/>
        </mxCell>

        <!-- Bottom note spanning all zones -->
        <mxCell id="bottom_note" value="Sicherheit: Alle Tokens über HTTPS · Secret Manager für Service-Credentials · Workload Identity für GCP-Auth" style="fillColor=#d5e8d4;strokeColor=#82b366;whiteSpace=wrap;html=1;rounded=1;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="800" width="1400" height="45" as="geometry"/>
        </mxCell>

        <!-- Arrows within Zone 1 (flow) -->
        <mxCell id="z1_e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z1_sdk" target="z1_login" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="z1_e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z1_login" target="z1_create" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="z1_e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z1_create" target="z1_jwt" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="z1_e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z1_jwt" target="z1_bearer" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Zone 1 → Zone 2 -->
        <mxCell id="z1_z2" value="JWT Bearer" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z1_bearer" target="z2_host" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Zone 2 internal flow -->
        <mxCell id="z2_e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z2_host" target="z2_verify" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Zone 2 → Firebase (dashed orange) -->
        <mxCell id="z2_fb" value="verifyIdToken" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;strokeColor=#f9a825;" edge="1" source="z2_verify" target="firebase_ext" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="z2_e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z2_verify" target="z2_result" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="z2_e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z2_result" target="z2_cache" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="z2_e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z2_cache" target="z2_decision" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Decision → 403 (Nein) -->
        <mxCell id="z2_no" value="Nein" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#b85450;" edge="1" source="z2_decision" target="z2_403" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Decision → inject (Ja) -->
        <mxCell id="z2_yes" value="Ja" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#82b366;" edge="1" source="z2_decision" target="z2_inject" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Zone 2 → Zone 3 (injected headers) -->
        <mxCell id="z2_z3" value="injected headers" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z2_inject" target="z3_mw" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Zone 3 internal flow -->
        <mxCell id="z3_e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z3_mw" target="z3_note" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="z3_e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z3_note" target="z3_roles" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="z3_e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z3_roles" target="z3_db" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="z3_e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="z3_db" target="z3_pool" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
