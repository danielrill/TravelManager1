<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-06-26" version="21.0.0">
  <diagram name="Multi-Tenancy" id="multi-tenancy">
    <mxGraphModel dx="1800" dy="1000" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1800" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Multi-Tenancy Modell — Hybrid-Architektur" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="5" width="1000" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Subdomain → tenantId → Datenbankrouting" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="38" width="1000" height="25" as="geometry"/>
        </mxCell>

        <!-- ROW 1 — Tier Labels -->
        <mxCell id="tier_free" value="FREE TIER&#xa;(tenantId: &apos;default&apos;)" style="fillColor=#f5f5f5;strokeColor=#4a90d9;strokeWidth=2;verticalAlign=top;fontStyle=1;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="450" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="tier_standard" value="STANDARD TIER&#xa;(tenantId: &apos;tui&apos;)" style="fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="80" width="450" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="tier_enterprise" value="ENTERPRISE TIER&#xa;(tenantId: &apos;enterprise-abc&apos;)" style="fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1160" y="80" width="450" height="50" as="geometry"/>
        </mxCell>

        <!-- ROW 2 — Shared Routing Banner -->
        <mxCell id="routing" value="onecloudaway.de · tui.onecloudaway.de · abc.onecloudaway.de&#xa;Nginx → Host-Header-Parsing → tenantId" style="fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;rounded=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="170" width="1530" height="60" as="geometry"/>
        </mxCell>

        <!-- FREE TIER Resources -->
        <mxCell id="free_pg" value="Shared PostgreSQL&#xa;(Cloud SQL)" style="shape=mxgraph.basic.rect;fillColor=#d5e8d4;strokeColor=#82b366;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="310" width="160" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="free_pods" value="Shared App Pods&#xa;(alle 8 Services geteilt)" style="fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="430" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="free_redis" value="Redis (geteilt)" style="fillColor=#d5e8d4;strokeColor=#82b366;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="530" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="free_rate" value="Rate-Limit: 60 req/min&#xa;Preis: $0" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="610" width="250" height="40" as="geometry"/>
        </mxCell>

        <!-- STANDARD TIER Resources -->
        <mxCell id="std_pg" value="Dedicated Postgres-Pod&#xa;postgres-tui:5432&#xa;StatefulSet + 5GiB PVC" style="fillColor=#ffe6cc;strokeColor=#d6b656;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="710" y="310" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="std_pods" value="Shared App Pods&#xa;(Shared trip/social routes to dedicated DB)" style="fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="710" y="430" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="std_rate" value="Rate-Limit: 600 req/min&#xa;Preis: €29,99 + Usage" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="640" y="520" width="260" height="40" as="geometry"/>
        </mxCell>

        <!-- ENTERPRISE TIER Resources -->
        <mxCell id="ent_pg" value="Dedicated Postgres-Pod&#xa;postgres-abc:5432" style="fillColor=#ffe6cc;strokeColor=#d6b656;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1250" y="310" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="ent_trip" value="Dedicated trip-service-abc&#xa;Deployment + HPA" style="fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1250" y="430" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ent_social" value="Dedicated social-service-abc&#xa;Deployment + HPA" style="fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1250" y="520" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ent_netpol" value="NetworkPolicy&#xa;(Ingress nur von eigenen Pods)" style="fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;whiteSpace=wrap;html=1;rounded=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1250" y="610" width="190" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ent_rate" value="Rate-Limit: 6000 req/min" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1200" y="680" width="260" height="30" as="geometry"/>
        </mxCell>

        <!-- BOTTOM: Provisioner box -->
        <mxCell id="provisioner" value="Provisioner-Service — K8s StatefulSet + NetworkPolicy automatisch erstellt" style="fillColor=#fff2cc;strokeColor=#d6b656;whiteSpace=wrap;html=1;rounded=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="740" width="1530" height="60" as="geometry"/>
