# Trip Service — owns the Trip DB. Publishes TripCreated / TripUpdated.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/travelmanager_trip
NITRO_PORT=3002
DESTINATION_SERVICE_URL=http://localhost:3003
# Firestore (likes/reviews comments)
GOOGLE_CLOUD_PROJECT=
FIREBASE_SERVICE_ACCOUNT=
FIRESTORE_DATABASE_ID=onecloudaway-db
# Pub/Sub: set PUBSUB_DISABLED=1 to no-op locally
PUBSUB_DISABLED=1
# Vertex AI embeddings (recommendations). VERTEX_DISABLED=1 makes embed() a
# null-returning no-op (local/CI without GCP creds); embeddings get backfilled
# once creds + pgvector are present. Region defaults to europe-west1.
VERTEX_DISABLED=1
VERTEX_LOCATION=europe-west1
DEV_USER_UID=
