# API Gateway — single entry point. No database.
NITRO_PORT=3000
USER_SERVICE_URL=http://localhost:3001
TRIP_SERVICE_URL=http://localhost:3002
DESTINATION_SERVICE_URL=http://localhost:3003
SOCIAL_SERVICE_URL=http://localhost:3004
TRAVEL_INFO_SERVICE_URL=http://localhost:3005
# Firebase Admin creds for JWT verify
GOOGLE_CLOUD_PROJECT=
FIREBASE_SERVICE_ACCOUNT=
# Local dev without Firebase: trust x-debug-uid header instead of a real token.
GATEWAY_SKIP_AUTH=1
