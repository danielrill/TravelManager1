# Metering service config (12-Factor: all config from env).
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/travelmanager
USER_SERVICE_URL=http://localhost:3001

# Pub/Sub subscription for UsageRecorded (provisioned in TravelManagerIaC).
USAGE_SUB=metering-usage-sub

# Local dev: disable Pub/Sub (no subscriber); drive ingest via POST /api/events/usage
# or the seat-snapshot task instead.
PUBSUB_DISABLED=1

# GCP project (Pub/Sub auth in prod via Workload Identity).
GOOGLE_CLOUD_PROJECT=
