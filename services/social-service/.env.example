# Social Service — owns the Social DB. Consumes TripCreated/TripUpdated,
# publishes NewsletterReady.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/travelmanager_social
NITRO_PORT=3004
TRIP_CREATED_SUB=social-trip-created-sub
TRIP_UPDATED_SUB=social-trip-updated-sub
# Newsletter job fans out to these to list users + fetch their recommendations.
USER_SERVICE_URL=http://localhost:3001
TRIP_SERVICE_URL=http://localhost:3002
PUBSUB_DISABLED=1
