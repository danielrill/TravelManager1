# Firebase Web API key.
# This IS the same value as NUXT_PUBLIC_FIREBASE_API_KEY in your app's .env
# (the "your-web-api-key" line). Copy it verbatim.
# Find it in Firebase Console → Project settings → General → Your apps → Web app → apiKey
FIREBASE_API_KEY=

# Path to Firebase Admin SDK service account JSON (download from Firebase Console).
# OPTIONAL — leave blank if your org policy blocks key creation; the seeder
# will fall back to Application Default Credentials. Run first:
#   gcloud auth application-default login
#   gcloud config set project <PROJECT_ID>
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Required for ADC fallback (so Admin SDK knows which Firebase project)
NUXT_PUBLIC_FIREBASE_PROJECT_ID=

# How many test users to seed
TEST_USER_COUNT=50

# Shared password for all seeded test accounts
TEST_USER_PASSWORD=LoadTest!2026

# Email domain used for seeded accounts
TEST_USER_EMAIL_DOMAIN=travelmanager.test

# Default target — overridden by --host flag on locust CLI
LOCUST_HOST=http://localhost:3000

# Comparison run targets (used by run_compare.sh)
TARGET_LOCAL=http://localhost:3000
TARGET_CLOUD_RUN=
TARGET_GCE=
